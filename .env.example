# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require"

# Auth (à configurer à l'étape Auth)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="CHANGE_ME"

# Intelligence & notifications
GEMINI_API_KEY="sk-gemini-xxxxx"
GEMINI_ENDPOINT="https://generativelanguage.googleapis.com/v1beta/models/gemini-proxy-001:generateText"
RESEND_API_KEY="re_XXXXXXXXXXXXXXXXXXXXXXXX"
RESEND_FROM="ops@rudore.africa"

# Scheduler
CRON_SECRET="CHANGE_ME_SECRET"

# API Security
INTERNAL_API_TOKEN="CHANGE_ME_TOKEN"
API_RATE_LIMIT="60"
API_RATE_LIMIT_WINDOW_MS="60000"
APP_URL="http://localhost:3000"
